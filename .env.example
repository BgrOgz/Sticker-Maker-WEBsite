# ============ AI IMAGE GENERATION ============
# Nano Banana API (Primary)
# Get from: https://app.nanobananab.com
NANO_BANANA_API_KEY=

# Alternative APIs (optional fallback)
# REPLICATE_API_KEY=
# STABILITY_API_KEY=
# OPENAI_API_KEY=

# ============ APP CONFIGURATION ============
# Local: http://localhost:3000
# Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

NODE_ENV=development

# ============ AUTHENTICATION ============
# JWT Secret (generate random: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_key_change_in_production

# JWT Token Expiry
JWT_EXPIRY=30d

# Google OAuth
# Get from: https://console.cloud.google.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============ RATE LIMITING ============
RATE_LIMIT_REQUESTS_PER_HOUR=30
RATE_LIMIT_ANONYMOUS_PER_HOUR=5

# ============ DATABASE (Optional, v2+) ============
# DATABASE_URL=postgresql://user:password@host:5432/sticker_maker

# ============ MONITORING (Optional) ============
# SENTRY_DSN=
# VERCEL_ANALYTICS_ID=
